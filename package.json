{
  "name": "props-fuzzing",
  "version": "0.1.0",
  "description": "Type-driven props fuzzing for React, Vue, and Svelte components",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "default": "./dist/vue.js"
    },
    "./svelte": {
      "types": "./dist/svelte.d.ts",
      "default": "./dist/svelte.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "react",
    "vue",
    "svelte",
    "fuzzing",
    "property-based-testing",
    "typescript"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "svelte": "^5.0.0",
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "dependencies": {
    "@standard-schema/spec": "^1.1.0",
    "fast-check": "^4.3.0",
    "happy-dom": "^20.9.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@types/node": "^24.9.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "svelte": "^5.39.6",
    "valibot": "^1.3.1",
    "vite": "^7.1.12",
    "vitest": "^4.0.7",
    "vue": "^3.5.13",
    "zod": "^4.3.6"
  },
  "packageManager": "pnpm@10.33.0"
}
